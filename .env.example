# ─── OPERACIÓN ────────────────────────────────────────────────────────────────
# Modo de operación: paper (default, sin órdenes reales), alert, live
OPERATION_MODE=paper

# Kill switch global (true/false)
KILL_SWITCH=false

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# ─── AUTENTICACIÓN POLYMARKET ─────────────────────────────────────────────────
# Obtener en: https://clob.polymarket.com
# NUNCA commitear este archivo con valores reales

POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_WALLET_ADDRESS=

# Private key — NUNCA compartir, NUNCA commitear
# Solo necesaria para paper y live mode
POLYMARKET_PRIVATE_KEY=

# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# sqlite (default) o postgres
DATABASE_TYPE=sqlite

# SQLite: path relativo al proyecto
SQLITE_PATH=./data/polybot.db

# PostgreSQL: descomentar si DATABASE_TYPE=postgres
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/polybot

# ─── RIESGO ───────────────────────────────────────────────────────────────────
MAX_TOTAL_EXPOSURE_USDC=100.0
MAX_POSITION_SIZE_USDC=20.0
MIN_POSITION_SIZE_USDC=5.0
MAX_OPEN_POSITIONS=5
MAX_TRADES_PER_HOUR=20
MAX_POSITION_DURATION_HOURS=48.0
DAILY_STOP_LOSS_PCT=5.0
MAX_CONSECUTIVE_ORDER_FAILURES=5

# ─── ESTRATEGIA ───────────────────────────────────────────────────────────────
MIN_MARKET_LIQUIDITY_USDC=5000.0
MIN_MARKET_VOLUME_24H_USDC=1000.0
MAX_SPREAD_PCT=5.0
MAX_DAYS_TO_RESOLUTION=30
PREFERRED_HOURS_TO_RESOLUTION=72

# Thresholds de señales
MIN_EDGE_PCT=3.0
OVERROUND_THRESHOLD_PCT=2.0
PROBABILITY_SPIKE_THRESHOLD_PCT=8.0
MEAN_REVERSION_ZSCORE_THRESHOLD=2.0

# Exit policy
TAKE_PROFIT_PCT=8.0
TRAILING_STOP_PCT=3.0
PARTIAL_EXIT_THRESHOLD_1_PCT=20.0
PARTIAL_EXIT_SIZE_1_PCT=30.0
PARTIAL_EXIT_THRESHOLD_2_PCT=40.0
PARTIAL_EXIT_SIZE_2_PCT=50.0
MIN_HOURS_BEFORE_RESOLUTION_EXIT=2.0

# ─── NOTIFICACIONES (opcional) ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
